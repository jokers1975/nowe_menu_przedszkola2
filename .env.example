# ============================================================================
# Menu Catering — konfiguracja środowiska
# Skopiuj do .env i wypełnij.
# ============================================================================

# -- Supabase Cloud ----------------------------------------------------------
# Załóż darmowy projekt na https://supabase.com
# Klucze: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# -- Postgres (z Supabase) ---------------------------------------------------
# Project Settings → Database → Connection string → "Transaction" pooler.
# Hasło ustawiasz przy zakładaniu projektu (Database Password).
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-DB-PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# -- OpenRouter (AI) ---------------------------------------------------------
# Opcjonalnie. Można też wpisać w apce: /admin/settings
OPENROUTER_API_KEY=

# -- Admin -------------------------------------------------------------------
# Pierwszy user z tym emailem dostanie rolę super_admin automatycznie przy
# logowaniu. Zmień na swój.
SUPER_ADMIN_EMAIL=ty@twoja-domena.pl

# -- Runtime -----------------------------------------------------------------
# Port w kontenerze (compose mapuje go na hosta)
PORT=3000
